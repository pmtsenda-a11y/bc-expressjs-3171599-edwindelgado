# Variables de entorno para el ejercicio 01
# Copia este archivo como .env y ajusta los valores

# URL de conexión a PostgreSQL
# Formato: postgresql://usuario:contraseña@host:puerto/nombre_base_datos
DATABASE_URL="postgresql://bootcamp:bootcamp123@localhost:5432/bootcamp_dev"

# Puerto del servidor Express
PORT=3000

# Entorno de ejecución
NODE_ENV=development
