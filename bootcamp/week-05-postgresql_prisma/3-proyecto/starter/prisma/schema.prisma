// Prisma Schema — Proyecto Semana 05
// Adapta los modelos al dominio asignado por el instructor

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// TODO: Define tus modelos según tu dominio asignado
//
// Lineamientos:
//   - Recurso principal con mínimo 6 campos tipados
//   - Al menos un campo @unique (para demostrar P2002)
//   - Recurso secundario con relación 1:N
//   - Timestamps: createdAt y updatedAt
//
// Ejemplos:
//
// Biblioteca:
//   model Author { id Int @id @default(autoincrement()); name String; ... }
//   model Book   { id Int @id @default(autoincrement()); isbn String @unique; authorId Int; ... }
//
// Farmacia:
//   model Category   { id Int @id ...; name String @unique; ... }
//   model Medication { id Int @id ...; sku String @unique; categoryId Int?; ... }
//
model Author {
  id        Int      @id @default(autoincrement())
  name      String
  nationality String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  books     Book[]
}

model Book {
  id          Int      @id @default(autoincrement())
  title       String
  isbn        String   @unique
  year        Int
  pages       Int?
  available   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  authorId    Int?
  author      Author?  @relation(fields: [authorId], references: [id], onDelete: SetNull)
}
